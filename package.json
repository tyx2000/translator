{
  "name": "vocabulary-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to=.wrangler/state",
    "deploy": "wrangler deploy",
    "wrangler:from-env": "node scripts/write-wrangler-config.mjs",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply vocabulary --local",
    "db:migrate:remote": "wrangler d1 migrations apply vocabulary --remote",
    "dictionary:download": "node scripts/download-dictionary.mjs",
    "dictionary:build": "node scripts/build-dictionary-kv.mjs",
    "dictionary:import:local": "node scripts/import-dictionary-kv.mjs --local",
    "dictionary:import:remote": "node scripts/import-dictionary-kv.mjs --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "csv-parse": "^7.0.1",
    "typescript": "^5.5.4",
    "wrangler": "^4.0.0"
  }
}
